# ==========================================
# SercofiRH — Variáveis de Ambiente
# ==========================================
# Copie este arquivo para .env e preencha os valores.
# O sistema FALHA NA STARTUP se variáveis obrigatórias estiverem ausentes.

# ==========================================
# APP
# ==========================================
NODE_ENV=development
PORT=3000
API_VERSION=v1
FRONTEND_URL=http://localhost:3001

# ==========================================
# DATABASE (obrigatório)
# ==========================================
DATABASE_URL=postgresql://sercofi:sercofi_dev_123@localhost:5432/sercofi_rh

# ==========================================
# AUTH (obrigatório)
# ==========================================
JWT_SECRET=change-me-in-production-use-keyvault
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d
PEPPER_SECRET=change-me-in-production-use-keyvault

# ==========================================
# AZURE BLOB STORAGE (obrigatório)
# ==========================================
# Local (Azurite): UseDevelopmentStorage=true
AZURE_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true
AZURE_STORAGE_CONTAINER_NAME=cartoes-ponto

# ==========================================
# AZURE DOCUMENT INTELLIGENCE (obrigatório para OCR)
# ==========================================
AZURE_DOC_INTEL_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_DOC_INTEL_KEY=your-key

# ==========================================
# AZURE OPENAI (obrigatório para AI Filter)
# ==========================================
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_KEY=your-key
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-01-preview

# ==========================================
# REDIS / BULLMQ (obrigatório)
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ==========================================
# AZURE APPLICATION INSIGHTS (opcional em dev)
# ==========================================
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ==========================================
# AZURE KEY VAULT (produção apenas)
# ==========================================
AZURE_KEY_VAULT_URL=
