generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// MULTI-TENANCY
// ============================================

model Tenant {
  id        String   @id @default(uuid())
  nome      String
  cnpj      String   @unique
  plano     Plano    @default(STARTER)
  ativo     Boolean  @default(true)
  suspenso  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuarios     User[]
  empresas     Empresa[]
  uploads      Upload[]
  featureFlags FeatureFlag[]

  @@map("tenants")
}

enum Plano {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

// ============================================
// AUTENTICAÇÃO E AUTORIZAÇÃO
// ============================================

model User {
  id                 String    @id @default(uuid())
  tenantId           String
  email              String
  passwordHash       String
  nome               String
  role               Role      @default(ANALISTA)
  ativo              Boolean   @default(true)
  mustChangePassword Boolean   @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  createdBy          String?
  updatedBy          String?

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  revisoes  Revisao[]
  auditLogs AuditLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  SUPERVISOR
  ANALISTA
}

// ============================================
// EMPRESAS-CLIENTE
// ============================================

model Empresa {
  id             String   @id @default(uuid())
  tenantId       String
  razaoSocial    String
  cnpj           String
  nomeFantasia   String?
  contato        String?
  telefone       String?
  email          String?
  jornadaSegSex  String?
  intervaloAlmoco String?
  jornadaSabado  String?
  ativo          Boolean  @default(true)
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdBy      String?
  updatedBy      String?

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  funcionarios Funcionario[]
  uploads      Upload[]

  @@unique([tenantId, cnpj])
  @@index([tenantId])
  @@map("empresas")
}

// ============================================
// FUNCIONÁRIOS
// ============================================

model Funcionario {
  id        String    @id @default(uuid())
  tenantId  String
  empresaId String
  nome      String
  cargo     String?
  cpf       String?
  matricula String?
  ativo     Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  empresa      Empresa       @relation(fields: [empresaId], references: [id])
  cartoesPonto CartaoPonto[]

  @@unique([tenantId, empresaId, cpf])
  @@index([tenantId])
  @@index([empresaId])
  @@map("funcionarios")
}

// ============================================
// UPLOAD E PROCESSAMENTO
// ============================================

model Upload {
  id            String       @id @default(uuid())
  tenantId      String
  empresaId     String
  userId        String
  mesReferencia String
  nomeArquivo   String
  blobUrl       String
  blobPath      String
  tamanhoBytes  Int
  totalPaginas  Int?
  paginasProcessadas Int?
  paginasFalhadas    Int?
  fileHash      String?      @unique
  version       Int          @default(1)
  status        UploadStatus @default(AGUARDANDO)
  erroMensagem  String?
  processadoEm  DateTime?
  deletedAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  empresa             Empresa              @relation(fields: [empresaId], references: [id])
  cartoesPonto        CartaoPonto[]
  pageClassifications PageClassification[]
  pipelineMetrics     PipelineMetrics?

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([empresaId, mesReferencia])
  @@map("uploads")
}

enum UploadStatus {
  AGUARDANDO
  PROCESSANDO
  PROCESSADO
  PROCESSADO_PARCIAL
  ERRO
  VALIDADO
  EXPORTADO
}

// ============================================
// CARTÃO DE PONTO
// ============================================

model CartaoPonto {
  id                String        @id @default(uuid())
  tenantId          String
  uploadId          String
  funcionarioId     String?
  paginaPdf         Int
  nomeExtraido      String?
  cargoExtraido     String?
  mesExtraido       String?
  empresaExtraida   String?
  cnpjExtraido      String?
  horarioContratual String?
  tipoCartao        TipoCartao    @default(DESCONHECIDO)
  statusRevisao     StatusRevisao @default(PENDENTE)
  confiancaGeral       Float?
  skipReason           String?
  pipelineVersion      Int           @default(1)
  prioridadeRevisao    Float?
  prioridadeMotivos    Json?
  ocrRawData           Json?

  // Campos v2 (agrupamento quinzenal)
  tipoCartaoFormato    String        @default("mensal")  // 'mensal' | 'quinzenal'
  paginaVerso          Int?                               // null se mensal
  mergeValidado        Boolean       @default(true)       // false se houve warning no merge

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  upload       Upload        @relation(fields: [uploadId], references: [id])
  funcionario  Funcionario?  @relation(fields: [funcionarioId], references: [id])
  batidas      Batida[]
  revisoes     Revisao[]
  ocrFeedback  OcrFeedback[]
  groundTruth  GroundTruth[]

  @@index([tenantId])
  @@index([uploadId])
  @@index([tenantId, statusRevisao])
  @@index([tenantId, statusRevisao, prioridadeRevisao])
  @@map("cartoes_ponto")
}

enum TipoCartao {
  ELETRONICO
  MANUSCRITO
  HIBRIDO
  DESCONHECIDO
}

enum PageType {
  CARTAO_PONTO_MENSAL
  CARTAO_PONTO_QUINZENAL
  ESPELHO_PONTO
  PAGINA_ASSINATURA
  PAGINA_SEM_TABELA
  PAGINA_FINANCEIRA
  DOCUMENTO_DESCONHECIDO
}

model PageClassification {
  id             String   @id @default(uuid())
  tenantId       String
  uploadId       String
  paginaPdf      Int
  pageType       PageType
  subFormat      String?
  confidence     Float
  shouldProcess  Boolean  @default(true)
  classifierData Json?
  createdAt      DateTime @default(now())

  upload Upload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@unique([uploadId, paginaPdf])
  @@index([tenantId])
  @@index([uploadId])
  @@map("page_classifications")
}

enum StatusRevisao {
  PENDENTE
  EM_REVISAO
  APROVADO
  REJEITADO
}

// ============================================
// BATIDAS
// ============================================

model Batida {
  id            String  @id @default(uuid())
  tenantId      String
  cartaoPontoId String
  dia           Int
  diaSemana     String?

  entradaManha String?
  saidaManha   String?
  entradaTarde String?
  saidaTarde   String?
  entradaExtra String?
  saidaExtra   String?

  entradaManhaCorrigida String?
  saidaManhaCorrigida   String?
  entradaTardeCorrigida String?
  saidaTardeCorrigida   String?
  entradaExtraCorrigida String?
  saidaExtraCorrigida   String?

  horasNormais Float?
  horasExtras  Float?
  confianca    Json?

  isManuscrito    Boolean  @default(false)
  isInconsistente Boolean  @default(false)
  isFaltaDia      Boolean  @default(false)
  observacao      String?

  gptFailed         Boolean @default(false)
  consistencyIssues Json?
  outlierFlags      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cartaoPonto CartaoPonto  @relation(fields: [cartaoPontoId], references: [id], onDelete: Cascade)
  ocrFeedback OcrFeedback[]
  groundTruth GroundTruth[]

  @@unique([cartaoPontoId, dia])
  @@index([tenantId])
  @@index([cartaoPontoId])
  @@map("batidas")
}

// ============================================
// OCR FEEDBACK (DI vs GPT vs Human)
// ============================================

model OcrFeedback {
  id            String   @id @default(uuid())
  tenantId      String
  batidaId      String
  cartaoPontoId String
  dia           Int
  campo         String
  valorDi       String?
  valorGpt      String?
  valorFinal    String?
  valorHumano   String?
  concordaDiGpt Boolean?

  // Campos v2 (multi-extrator com votacao)
  valorMiniA    String?
  valorMiniB    String?
  valorMiniC    String?
  fonteDecisao  String?
  usouFallback  Boolean   @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  batida      Batida      @relation(fields: [batidaId], references: [id], onDelete: Cascade)
  cartaoPonto CartaoPonto @relation(fields: [cartaoPontoId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([batidaId])
  @@index([cartaoPontoId])
  @@map("ocr_feedback")
}

// ============================================
// TENANT OCR CONFIG
// ============================================

model TenantOcrConfig {
  id                    String   @id @default(uuid())
  tenantId              String   @unique
  timeFieldRanges       Json?
  minLunchBreakMinutes  Int      @default(60)
  maxWorkdayMinutes     Int      @default(600)
  reviewThreshold       Float    @default(0.80)
  gptSkipThreshold      Float    @default(0.90)
  outlierZWarning       Float    @default(2.0)
  outlierZError         Float    @default(3.0)
  outlierMinDays        Int      @default(5)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([tenantId])
  @@map("tenant_ocr_configs")
}

// ============================================
// PIPELINE METRICS
// ============================================

model PipelineMetrics {
  id                   String   @id @default(uuid())
  tenantId             String
  uploadId             String   @unique
  totalPaginas         Int
  paginasProcessadas   Int
  paginasFalhadas      Int
  paginasIgnoradas     Int      @default(0)
  tempoDocIntel        Int?
  tempoClassifier      Int?
  tempoParser          Int?
  tempoSanitizer       Int?
  tempoScorer          Int?
  tempoConsistency     Int?
  tempoGatekeeper      Int?
  tempoGptVision       Int?
  tempoOutlier         Int?
  tempoOrchestrator    Int?
  tempoGptMini         Int?
  tempoGptVision52     Int?
  tempoImageCropping   Int?
  tempoTotal           Int
  totalBatidas         Int      @default(0)
  batidasRevisao       Int      @default(0)
  correcoesSanitizer   Int      @default(0)
  chamadasGpt          Int      @default(0)
  gptPuladas           Int      @default(0)
  gptTokensIn          Int      @default(0)
  gptTokensOut         Int      @default(0)
  gptCustoDolar        Float?
  chamadasMini         Int      @default(0)
  chamadasGpt52        Int      @default(0)
  gpt52Skipped         Int      @default(0)
  miniTokensIn         Int      @default(0)
  miniTokensOut        Int      @default(0)
  gpt52TokensIn        Int      @default(0)
  gpt52TokensOut       Int      @default(0)
  miniCustoDolar       Float?
  gpt52CustoDolar      Float?
  concordanciaDiGpt    Float?
  classificacaoPaginas Json?

  // Campos v2 (multi-extrator com votacao)
  pipelineVersion           String   @default("v1")
  paginasResolvidasVotacao  Int      @default(0)
  paginasFallback52         Int      @default(0)
  taxaConcordancia3de3      Float?
  taxaConcordancia2de3      Float?
  taxaDivergenciaTotal      Float?
  custoEstimadoMini         Float?
  custoEstimadoDI           Float?
  custoEstimado52           Float?
  custoEstimadoTotal        Float?

  createdAt            DateTime @default(now())

  upload Upload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("pipeline_metrics")
}

// ============================================
// REVISÃO E AUDITORIA
// ============================================

model Revisao {
  id            String      @id @default(uuid())
  tenantId      String
  cartaoPontoId String
  userId        String
  acao          AcaoRevisao
  campo         String?
  valorAnterior String?
  valorNovo     String?
  observacao    String?
  createdAt     DateTime    @default(now())

  cartaoPonto CartaoPonto @relation(fields: [cartaoPontoId], references: [id])
  user        User        @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([cartaoPontoId])
  @@map("revisoes")
}

enum AcaoRevisao {
  CORRECAO
  APROVACAO
  REJEICAO
  OBSERVACAO
}

// ============================================
// GROUND TRUTH (Dataset de Avaliação)
// ============================================

model GroundTruth {
  id              String     @id @default(uuid())
  tenantId        String
  cartaoPontoId   String
  batidaId        String
  dia             Int
  campo           String
  valorDi         String?
  valorGpt        String?
  valorSanitizer  String?
  valorFinal      String?
  valorHumano     String?
  acertouDi       Boolean?
  acertouGpt      Boolean?
  acertouSanitizer Boolean?
  tipoCartao      TipoCartao
  isManuscrito    Boolean    @default(false)
  createdAt       DateTime   @default(now())

  batida      Batida      @relation(fields: [batidaId], references: [id], onDelete: Cascade)
  cartaoPonto CartaoPonto @relation(fields: [cartaoPontoId], references: [id], onDelete: Cascade)

  @@unique([batidaId, campo])
  @@index([tenantId])
  @@index([cartaoPontoId])
  @@map("ground_truth")
}

// ============================================
// FEATURE FLAGS
// ============================================

model FeatureFlag {
  id        String   @id @default(uuid())
  tenantId  String
  feature   String
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, feature])
  @@index([tenantId])
  @@map("feature_flags")
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String
  acao       String
  entidade   String
  entidadeId String
  dados      Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([tenantId, entidade, entidadeId])
  @@index([createdAt])
  @@map("audit_logs")
}
